# Copy this file to application-dev.properties and fill in your local values
# Never commit application-dev.properties to git — it contains real secrets

# Database
spring.datasource.url=jdbc:mysql://localhost:3306/task_manager?createDatabaseIfNotExist=true
spring.datasource.username=<your_db_username>
spring.datasource.password=<your_db_password>

# JWT — used to sign httpOnly cookies
# Must be at least 32 characters (256 bits) for HMAC-SHA256
jwt.secret=<your_jwt_secret_min_32_chars>

# CORS — must match your frontend origin exactly (no trailing slash)
# Dev:  http://localhost:5173
# Prod: https://yourapp.com
cors.allowed-origin=<your_frontend_url>

# Cookie secure flag — set to true in production (requires HTTPS)
cookie.secure=false

# Logging (optional overrides)
# logging.level.com.example.taskmanager=DEBUG
