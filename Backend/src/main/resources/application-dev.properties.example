# Dev profile overrides — copy this to application-dev.properties and fill in your values
# NEVER commit real credentials — add application-dev.properties to .gitignore
spring.datasource.url=jdbc:mysql://localhost:3306/task_manager?createDatabaseIfNotExist=true
spring.datasource.username=root
spring.datasource.password=your_local_db_password

# Override production 'validate' — allow schema auto-update in local dev only
spring.jpa.hibernate.ddl-auto=update

# JWT secret for local dev — must be at least 32 characters
jwt.secret=your_local_dev_jwt_secret_min_32_chars

# CORS — frontend dev server
cors.allowed-origin=http://localhost:5173

# Cookie — false for http localhost, true for https production
cookie.secure=false

# Show SQL queries in dev
spring.jpa.show-sql=true

# Logging — show DEBUG logs for our app in dev, keep Spring noise at INFO
logging.level.com.example.taskmanager=DEBUG
logging.level.org.springframework=INFO
